generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String?
  phoneNumber   String?
  role          String   @default("CUSTOMER") // CUSTOMER, PROVIDER, ADMIN
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  providerProfile ProviderProfile?
  jobsAsCustomer  Job[]            @relation("CustomerJobs")
}

model ProviderProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  category       String
  dailyRate      Float
  goPayNumber    String?
  isVerified     Boolean @default(false)

  // Profile enrichment (powers the premium UI)
  bio            String?
  avatarUrl      String?
  rating         Float   @default(0)
  ratingCount    Int     @default(0)
  completedJobs  Int     @default(0)

  latitude       Float?
  longitude      Float?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobsAsProvider Job[]   @relation("ProviderJobs")

  @@index([category])
  @@index([isVerified])
}

model Job {
  id                 String    @id @default(uuid())
  customerId         String
  providerProfileId  String

  customer           User             @relation("CustomerJobs", fields: [customerId], references: [id])
  provider           ProviderProfile  @relation("ProviderJobs", fields: [providerProfileId], references: [id])

  status             String @default("PENDING") // PENDING, ONGOING, COMPLETED, CANCELLED

  estimatedDays      Int
  customerAddress    String
  customerWaNumber   String
  notes              String?
  isConsentGiven     Boolean   @default(true)

  totalFee           Float
  platformCommission Float
  providerPayout     Float

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  payments           Payment[]

  @@index([providerProfileId])
  @@index([status])
}

model Payment {
  id            String   @id @default(uuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  amount        Float
  type          String   // DP, FULL_SETTLEMENT
  status        String   @default("PENDING") // PENDING, SUCCESS, FAILED
  midtransTrxId String?  @unique

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
