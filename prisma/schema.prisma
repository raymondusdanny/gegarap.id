generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  // Canonical, normalised WhatsApp login identity (format: 628xxxxxxxxxx).
  // Set when a user authenticates via WhatsApp OTP. Distinct from the legacy
  // free-form `phoneNumber` used for display/contact.
  phone           String?          @unique
  passwordHash    String?
  phoneNumber     String?
  role            String           @default("CUSTOMER")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  jobsAsCustomer  Job[]            @relation("CustomerJobs")
  providerProfile ProviderProfile?
}

model OtpToken {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model ProviderProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  category       String
  dailyRate      Float
  goPayNumber    String?
  isVerified     Boolean  @default(false)
  bio            String?
  avatarUrl      String?
  rating         Float    @default(0)
  ratingCount    Int      @default(0)
  completedJobs  Int      @default(0)
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  jobsAsProvider Job[]    @relation("ProviderJobs")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([isVerified])
}

model Job {
  id                 String          @id @default(uuid())
  customerId         String
  providerProfileId  String
  status             String          @default("PENDING")
  estimatedDays      Int
  customerAddress    String
  customerWaNumber   String
  notes              String?
  isConsentGiven     Boolean         @default(true)
  totalFee           Float
  platformCommission Float
  providerPayout     Float
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  customer           User            @relation("CustomerJobs", fields: [customerId], references: [id])
  provider           ProviderProfile @relation("ProviderJobs", fields: [providerProfileId], references: [id])
  payments           Payment[]

  @@index([providerProfileId])
  @@index([status])
}

model Payment {
  id            String   @id @default(uuid())
  jobId         String
  amount        Float
  type          String
  status        String   @default("PENDING")
  midtransTrxId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
