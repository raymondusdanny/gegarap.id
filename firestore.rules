rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Auth profile, document id == Firebase Auth uid. A user may read/write only
    // their OWN document. `list` is denied so nobody can enumerate users or map
    // a WhatsApp number to an email from the client — those lookups run server
    // side via the Admin SDK (see /api/auth/resolve-identifier).
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow list, delete: if false;
    }
  }
}
