# Database — PostgreSQL (Docker). Matches docker-compose.yml defaults.
DATABASE_URL="postgresql://gegarap:gegarap_secret@localhost:5432/gegarap_db?schema=public"

# Postgres container credentials (read by docker-compose.yml)
POSTGRES_USER=gegarap
POSTGRES_PASSWORD=gegarap_secret
POSTGRES_DB=gegarap_db
POSTGRES_PORT=5432

# Google OAuth — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
