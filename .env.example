# Database — managed PostgreSQL (no Docker). Create a free database on Neon
# (https://neon.tech) or Supabase (https://supabase.com) and paste its connection
# string here. The same string is used for local dev and production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Base URL of the app, used to build dashboard deep-links in notifications.
APP_URL=http://localhost:3000

# ─── Firebase (Authentication + Firestore) ──────────────────────────────────
# Public client config (safe to ship — access is governed by security rules).
# From Firebase Console → Project settings → your web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Use the local emulators in dev (`true`); set `false` (or unset) in production.
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# Admin SDK. In production set this to the JSON service-account key (one line).
# Leave EMPTY in local dev — the Admin SDK auto-targets the emulators via the
# two *_EMULATOR_HOST vars below.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Local-only: make the Admin SDK (server) talk to the emulators, not production.
# Leave these UNSET in production.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Opt-in: also create Firebase Auth users when seeding (emulator only), so seeded
# accounts are loginable with SEED_PASSWORD. Default off (Postgres-only seed).
SEED_FIREBASE=false
SEED_PASSWORD=Password123

# WhatsApp notifikasi via Meta WhatsApp Cloud API (Official).
# https://developers.facebook.com/docs/whatsapp/cloud-api
# Dipakai untuk notifikasi booking/payout/ops (BUKAN lagi untuk OTP — OTP sudah
# dihapus dari alur auth). Bila kredensial kosong di dev, notifikasi hanya
# di-log ke console agar alur tetap bisa diuji tanpa akun Meta.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Opsional — default mengikuti kode bila dikosongkan.
WHATSAPP_API_VERSION=v18.0

# Midtrans (Snap). If MIDTRANS_SERVER_KEY is unset in dev, payments are mocked
# (no Snap popup) so the booking flow stays testable locally.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# Optional channel allow-list. LEAVE EMPTY (or "all") so Snap auto-detects every
# channel active on your merchant account — the safe default. NEVER set this to a
# value that resolves to an empty list (that causes "No payment channels
# available"). Use "default" for the curated set, or a CSV of channel names
# (e.g. gopay,bca_va,shopeepay) to force a specific list.
MIDTRANS_ENABLED_PAYMENTS=

# Manual bank-transfer fallback. If the gateway is unreachable AND these three
# are set, a booking falls back to bank-transfer instructions instead of failing.
# Leave empty to disable the fallback (gateway errors then surface to the user).
MANUAL_TRANSFER_BANK=
MANUAL_TRANSFER_ACCOUNT=
MANUAL_TRANSFER_HOLDER=

# Risk scoring: score (0-100) at/above which a booking is HARD-BLOCKED. Leave
# empty to flag-only (recommended) — HIGH-risk bookings are flagged for ops but
# never auto-rejected. Set e.g. 90 to start blocking the most extreme.
RISK_BLOCK_THRESHOLD=

# Email (Resend) for the DP receipt (nota) + PDF attachment, sent on payment
# success. Optional like Midtrans: if EMAIL_API_KEY is unset the send is a logged
# no-op so dev/build stays green. EMAIL_FROM must be a Resend-verified sender.
EMAIL_FROM=gegarap.id <noreply@gegarap.id>
EMAIL_API_KEY=

# Anthropic (Claude) for the AI assistant (System 4). Optional like the others:
# without ANTHROPIC_API_KEY the assistant falls back to a deterministic,
# RAG-grounded recommendation (no LLM call) so dev/build stays green.
ANTHROPIC_API_KEY=

# Support contact (public). Surfaced in footer, legal pages, and help CTAs.
# REQUIRED for production — `npm run build` fails if any is missing or still a
# placeholder (scripts/check-env.mjs). In dev, leave blank to hide the CTAs.
# WA = international format, no + and no leading 0 (e.g. 6281234567890).
NEXT_PUBLIC_WA_SUPPORT=
NEXT_PUBLIC_EMAIL_SUPPORT=
NEXT_PUBLIC_EMAIL_PRIVACY=

# Supabase Storage for KTP (KYC) uploads. If unset in dev, uploads return a
# placeholder URL so onboarding can be completed without a Supabase account.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=ktp-uploads

# Cron auth (Bagian 5/11). Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`.
# Generate with: openssl rand -base64 32. If unset, cron routes are callable only
# outside production. Used by /api/cron/* (auto-cancel, reconcile, auto-release,
# dispatch-outbox).
CRON_SECRET=

# Rate limiting. If BOTH are set, the limiter uses Upstash Redis — an
# AUTHORITATIVE cross-instance limit (required on serverless/Vercel, where each
# lambda otherwise keeps its own private counter). If unset, it falls back to a
# best-effort per-instance in-memory limiter. Create a free DB at upstash.com.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Real provider disbursement (Bagian 6). Default is a safe MOCK that never moves
# money. Set DISBURSEMENT_PROVIDER=gateway AND MIDTRANS_IRIS_API_KEY to enable
# real Midtrans Iris payouts. Approval policy is configured on the Iris account.
DISBURSEMENT_PROVIDER=mock
MIDTRANS_IRIS_API_KEY=

# Observability (Bagian 10). If SENTRY_DSN is set AND `@sentry/nextjs` is
# installed, errors/alerts forward to Sentry (tagged paymentId/bookingId).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# WhatsApp number (628xxxx) that must-page alarms are sent to (financial
# mismatch, signature-failure spike, repeated disbursement/refund failures).
OPS_ALERT_PHONE=
